{
  "cleanUrls": true,
  "headers": [
    {
      "source": "/data/(.*).json",
      "headers": [
        { "key": "Content-Type", "value": "application/json" }
      ]
    },
    {
      "source": "/data/(.*).geojson",
      "headers": [
        { "key": "Content-Type", "value": "application/geo+json" }
      ]
    }
  ]
}
